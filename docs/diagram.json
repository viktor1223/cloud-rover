{
  "version": 1,
  "author": "Viktor Ciroski",
  "editor": "wokwi",
  "parts": [
    {
      "type": "chip-rpi3b",
      "id": "pi",
      "left": 200,
      "top": 80,
      "attrs": {}
    },
    {
      "type": "chip-pca9685",
      "id": "pwm",
      "left": 500,
      "top": 60,
      "attrs": {},
      "_note": "PCA9685 16-CH PWM driver. I2C address 0x40. Drives 4 DC motors via L298N. Using CH0-CH3 for direction (IN1-IN4) and CH4-CH5 for speed (ENA/ENB)."
    },
    {
      "type": "chip-l298n",
      "id": "bridge_ab",
      "left": 740,
      "top": 20,
      "attrs": { "Vs": "6" },
      "_note": "L298N #1: drives front-left (Ch A) and front-right (Ch B) motors."
    },
    {
      "type": "chip-l298n",
      "id": "bridge_cd",
      "left": 740,
      "top": 240,
      "attrs": { "Vs": "6" },
      "_note": "L298N #2: drives rear-left (Ch A) and rear-right (Ch B) motors."
    },
    {
      "type": "chip-dc-motor",
      "id": "motor_fl",
      "left": 940,
      "top": 20,
      "attrs": { "ratedV": "6" },
      "_note": "Front-left TT gearmotor. 3-6V, ~200RPM, dual shaft for encoder."
    },
    {
      "type": "chip-dc-motor",
      "id": "motor_fr",
      "left": 940,
      "top": 120,
      "attrs": { "ratedV": "6" },
      "_note": "Front-right TT gearmotor."
    },
    {
      "type": "chip-dc-motor",
      "id": "motor_rl",
      "left": 940,
      "top": 240,
      "attrs": { "ratedV": "6" },
      "_note": "Rear-left TT gearmotor."
    },
    {
      "type": "chip-dc-motor",
      "id": "motor_rr",
      "left": 940,
      "top": 340,
      "attrs": { "ratedV": "6" },
      "_note": "Rear-right TT gearmotor."
    },
    {
      "type": "chip-hcsr04",
      "id": "sonar",
      "left": 200,
      "top": 380,
      "attrs": {},
      "_note": "HC-SR04 ultrasonic distance sensor. Front-mounted. 5V logic, ECHO needs voltage divider."
    },
    {
      "type": "chip-adxl345",
      "id": "imu",
      "left": 40,
      "top": 80,
      "attrs": {},
      "_note": "GY-291 ADXL345 3-axis accelerometer. I2C address 0x53. Center-mounted on chassis."
    },
    {
      "type": "chip-battery",
      "id": "motor_battery",
      "left": 600,
      "top": 440,
      "attrs": { "voltage": "6" },
      "_note": "Motor power: 4×AA NiMH (4.8V) or alkaline (6V). Separate from logic supply."
    },
    {
      "type": "chip-battery",
      "id": "pi_battery",
      "left": 40,
      "top": 440,
      "attrs": { "voltage": "5" },
      "_note": "Logic power: 5V 2.5A USB power bank → Pi micro-USB. Also powers PCA9685 VCC and sensors."
    },
    {
      "type": "wokwi-resistor",
      "id": "r_echo1",
      "left": 340,
      "top": 400,
      "attrs": { "resistance": "1000" },
      "_note": "HC-SR04 ECHO voltage divider upper leg. 1kΩ."
    },
    {
      "type": "wokwi-resistor",
      "id": "r_echo2",
      "left": 340,
      "top": 430,
      "attrs": { "resistance": "2000" },
      "_note": "HC-SR04 ECHO voltage divider lower leg. 2kΩ to GND. Output: 5V × 2k/(1k+2k) = 3.33V."
    },
    {
      "type": "wokwi-led",
      "id": "led_status",
      "left": 40,
      "top": 20,
      "attrs": { "color": "green" },
      "_note": "Status LED on GPIO 18."
    },
    {
      "type": "wokwi-resistor",
      "id": "r_led",
      "left": 100,
      "top": 20,
      "attrs": { "resistance": "220" },
      "_note": "LED current limiter. (3.3V - 2V) / 220Ω = 5.9mA."
    }
  ],
  "connections": [
    ["pi:GPIO2", "pwm:SDA", "blue", []],
    ["pi:GPIO3", "pwm:SCL", "cyan", []],

    ["pi:GPIO2", "imu:SDA", "blue", []],
    ["pi:GPIO3", "imu:SCL", "cyan", []],

    ["pwm:CH0", "bridge_ab:IN1", "orange", []],
    ["pwm:CH1", "bridge_ab:IN2", "orange", []],
    ["pwm:CH2", "bridge_ab:IN3", "yellow", []],
    ["pwm:CH3", "bridge_ab:IN4", "yellow", []],
    ["pwm:CH4", "bridge_ab:ENA", "purple", []],
    ["pwm:CH5", "bridge_ab:ENB", "purple", []],

    ["pwm:CH6", "bridge_cd:IN1", "orange", []],
    ["pwm:CH7", "bridge_cd:IN2", "orange", []],
    ["pwm:CH8", "bridge_cd:IN3", "yellow", []],
    ["pwm:CH9", "bridge_cd:IN4", "yellow", []],
    ["pwm:CH10", "bridge_cd:ENA", "purple", []],
    ["pwm:CH11", "bridge_cd:ENB", "purple", []],

    ["bridge_ab:OUT1", "motor_fl:TERM1", "red", []],
    ["bridge_ab:OUT2", "motor_fl:TERM2", "brown", []],
    ["bridge_ab:OUT3", "motor_fr:TERM1", "red", []],
    ["bridge_ab:OUT4", "motor_fr:TERM2", "brown", []],

    ["bridge_cd:OUT1", "motor_rl:TERM1", "red", []],
    ["bridge_cd:OUT2", "motor_rl:TERM2", "brown", []],
    ["bridge_cd:OUT3", "motor_rr:TERM1", "red", []],
    ["bridge_cd:OUT4", "motor_rr:TERM2", "brown", []],

    ["motor_battery:+", "bridge_ab:12V", "red", []],
    ["motor_battery:-", "bridge_ab:GND", "black", []],
    ["motor_battery:+", "bridge_cd:12V", "red", []],
    ["motor_battery:-", "bridge_cd:GND", "black", []],

    ["pi_battery:+", "pi:5V.1", "red", []],
    ["pi_battery:-", "pi:GND.1", "black", []],

    ["pi:3.3V.1", "pwm:VCC", "orange", []],
    ["pi:GND.2", "pwm:GND", "black", []],
    ["motor_battery:+", "pwm:V+", "red", []],

    ["pi:3.3V.2", "imu:VCC", "orange", []],
    ["pi:GND.5", "imu:GND", "black", []],

    ["pi:5V.2", "sonar:VCC", "red", []],
    ["pi:GPIO24", "sonar:TRIG", "green", []],
    ["sonar:ECHO", "r_echo1:1", "darkgreen", []],
    ["r_echo1:2", "pi:GPIO25", "darkgreen", []],
    ["r_echo1:2", "r_echo2:1", "darkgreen", []],
    ["r_echo2:2", "pi:GND.4", "black", []],
    ["sonar:GND", "pi:GND.3", "black", []],

    ["bridge_ab:GND2", "pi:GND.6", "black", []],
    ["bridge_cd:GND2", "bridge_ab:GND2", "black", []],

    ["pi:GPIO18", "r_led:1", "green", []],
    ["r_led:2", "led_status:A", "green", []],
    ["led_status:C", "pi:GND.2", "black", []]
  ],
  "serialMonitor": { "display": "auto" },

  "_wiring_notes": {
    "description": "Cloud Rover — 4WD Wiring Diagram with PCA9685 PWM Driver",
    "architecture": "Pi 3B → I2C → PCA9685 → 2× L298N → 4× DC motors. All motor control via I2C, freeing GPIO for sensors.",
    "i2c_bus": {
      "GPIO2 (SDA)": ["PCA9685 (0x40)", "ADXL345 (0x53)"],
      "GPIO3 (SCL)": ["PCA9685 (0x40)", "ADXL345 (0x53)"],
      "note": "Both devices share the I2C bus. Different addresses, no conflict."
    },
    "pca9685_channel_mapping": {
      "CH0":  "L298N #1 IN1 (front-left direction A)",
      "CH1":  "L298N #1 IN2 (front-left direction B)",
      "CH2":  "L298N #1 IN3 (front-right direction A)",
      "CH3":  "L298N #1 IN4 (front-right direction B)",
      "CH4":  "L298N #1 ENA (front-left speed PWM)",
      "CH5":  "L298N #1 ENB (front-right speed PWM)",
      "CH6":  "L298N #2 IN1 (rear-left direction A)",
      "CH7":  "L298N #2 IN2 (rear-left direction B)",
      "CH8":  "L298N #2 IN3 (rear-right direction A)",
      "CH9":  "L298N #2 IN4 (rear-right direction B)",
      "CH10": "L298N #2 ENA (rear-left speed PWM)",
      "CH11": "L298N #2 ENB (rear-right speed PWM)",
      "CH12-CH15": "Available for future servos (camera pan/tilt, gripper)"
    },
    "gpio_usage": {
      "GPIO2 (SDA)": "I2C data — PCA9685 + ADXL345",
      "GPIO3 (SCL)": "I2C clock — PCA9685 + ADXL345",
      "GPIO18": "Status LED",
      "GPIO24": "HC-SR04 TRIG (output)",
      "GPIO25": "HC-SR04 ECHO (input, via voltage divider)",
      "available": "GPIO4, GPIO7-GPIO17, GPIO22-23, GPIO27 — all free for future sensors/encoders"
    },
    "power_design": {
      "motor_supply": {
        "source": "4× AA NiMH rechargeable (4.8V) or alkaline (6V)",
        "connects_to": ["L298N #1 12V", "L298N #2 12V", "PCA9685 V+ (servo rail)"],
        "notes": "L298N drops ~2V, motors see ~2.8-4V. Adequate for TT gearmotors. Both L298N share the same battery pack."
      },
      "logic_supply": {
        "source": "5V 2.5A USB power bank → Pi micro-USB",
        "powers": ["Raspberry Pi", "PCA9685 VCC (via Pi 3.3V)", "ADXL345 (via Pi 3.3V)", "HC-SR04 (via Pi 5V)"],
        "notes": "MUST be separate from motor power to prevent noise-induced crashes."
      },
      "common_ground": "All GND pins connected: Pi, PCA9685, both L298N, HC-SR04, ADXL345. Critical for signal integrity."
    },
    "motor_control_logic": {
      "FORWARD":  {"IN1": "HIGH", "IN2": "LOW", "IN3": "HIGH", "IN4": "LOW", "note": "All 4 motors forward"},
      "LEFT":     {"left_motors": "BACKWARD", "right_motors": "FORWARD", "note": "Skid steer left"},
      "RIGHT":    {"left_motors": "FORWARD", "right_motors": "BACKWARD", "note": "Skid steer right"},
      "STOP":     {"all": "LOW", "note": "All motors coast to stop"},
      "speed": "ENA/ENB PWM 0-4095 (12-bit). Start at 50% (2048)."
    },
    "sensor_specs": {
      "HC-SR04": {
        "range": "2cm - 400cm",
        "operating_voltage": "5V",
        "echo_output": "5V TTL — MUST use voltage divider (1kΩ/2kΩ) for Pi 3.3V GPIO",
        "trigger": "10µs pulse on TRIG pin",
        "measurement": "distance_cm = echo_pulse_us / 58"
      },
      "ADXL345 (GY-291)": {
        "range": "±2g / ±4g / ±8g / ±16g (selectable)",
        "resolution": "13-bit, 3.9mg/LSB at ±2g",
        "interface": "I2C (address 0x53) or SPI",
        "operating_voltage": "2.0V - 3.6V (GY-291 has onboard regulator for 5V input, but 3.3V direct is cleaner)",
        "data_rate": "up to 3200Hz",
        "use_case": "Tilt detection, collision detection, dead reckoning assist"
      },
      "ArduCam IMX708": {
        "connection": "CSI ribbon cable to Pi camera port",
        "resolution": "12MP, 640x480 @ 16 FPS (video pipeline)",
        "interface": "Built-in, no GPIO needed"
      }
    },
    "safety": {
      "voltage_divider": "REQUIRED on HC-SR04 ECHO. 5V into Pi GPIO = permanent damage.",
      "separate_power": "Motor and logic power MUST be separate supplies with common ground.",
      "decoupling_caps": "100nF ceramic across each motor terminal to suppress EMI.",
      "pca9685_oe_pin": "OE pin left floating (internal pull-down, outputs enabled). Tie to GPIO for emergency motor kill if desired."
    },
    "advantages_of_pca9685": [
      "Only 2 GPIO pins (I2C) control all 4 motors — frees GPIO for sensors",
      "12-bit PWM resolution (4096 steps) vs Pi hardware PWM (limited to 2 channels)",
      "Dedicated PWM clock — no CPU load for motor timing",
      "16 channels — 12 used for motors, 4 spare for camera servos or gripper",
      "Chainable — add a second PCA9685 (address 0x41) for 32 channels total"
    ]
  }
}
