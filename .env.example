# Cloud Rover — Environment Configuration
#
# Copy this to .env and edit for your setup.
# The Pi reads BRAIN_SERVER to know where to send frames.
# The brain server reads these to configure itself.

# Brain server WebSocket address (Pi connects to this)
# Change this when moving the brain to your 3070 desktop
BRAIN_HOST=0.0.0.0
BRAIN_WS_PORT=9091
BRAIN_HTTP_PORT=9090

# Which brain to use: heuristic, openvla, dreamer
BRAIN_NAME=heuristic

# YOLO settings (heuristic brain)
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4
